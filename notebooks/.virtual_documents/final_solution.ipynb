def gather_cli_info(df):
    """
    Za svakog klijenta uzmi sve redove i skupi sve ne-null 
    vrijednosti u jedan red.
    Ako ista kolona ima više različitih vrijednosti — uzmi najčešću.
    """
    def first_not_na(series):
        m = series.mode()
        return m.iloc[0] if not m.empty else np.nan

    return df.groupby('klijent_id').agg(first_not_na)


mp_cli_data = gather_cli_info(mp_cli_data)

